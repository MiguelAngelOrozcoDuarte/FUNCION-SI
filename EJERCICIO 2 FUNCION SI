Algoritmo EDAD
	// EN UNA EMPRESA, SE DESEA CALCULAR EL VALOR A PAGAR A UN EMPLEADO
	// LA EMPRESA PAGA A TRAVES DE LAS SIGUIENTES CONDICIONES
	// SI GANAS MAS O IGUAL A 1 MILLON, DEBE PAGARSELE UN RECARGO DEL 20%
	// SI GANA MENOS DE 1 MILLON, DEBE PAGARSELE UN RECARGO DEL 30%
	Escribir "PROGRAMA DE PAGO A UN EMPLEADO"
	Escribir "BIENVENIDO"
	Escribir ""
	Escribir ""
	Escribir "DIGITE SU NOMBRE"
	Leer NOMBRE
	Escribir "DIGITE SU SALARIO"
	LEER SALARIO
	SI SALARIO >= 1000000 Entonces
		TOTAL = SALARIO * 1.2
		Escribir "EL TOTAL A `PAGAR SERIA ", TOTAL
	SiNo
		TOTAL = SALARIO * 1.3
	FinSi
	
FinAlgoritmo
